<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.1</TargetFramework>
    <RootNamespace>GridDungeon.Core</RootNamespace>
    <AssemblyName>GridDungeon.Core</AssemblyName>
    <Description>Pure C# rules engine and DTOs mirrored from griddungeon-game Assets/Scripts/Core.</Description>
    <Authors>miramocha</Authors>
    <PackageId>GridDungeon.Core</PackageId>
    <Version>0.0.1</Version>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
